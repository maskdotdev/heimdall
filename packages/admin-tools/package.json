{
  "name": "@repo/admin-tools",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "admin": "bun run src/cli.ts",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests",
    "infra:db:prepare": "bun run src/prepare-local-infra.ts",
    "smoke:embedding:openai": "bun run src/live-openai-embedding-smoke.ts",
    "smoke:github-provider-errors": "bun run src/live-github-provider-error-smoke.ts",
    "smoke:publisher:github": "bun run src/live-github-publisher-smoke.ts",
    "smoke:review:github": "bun run src/live-github-pr-review-smoke.ts",
    "lint": "biome check .",
    "format": "biome format --write .",
    "clean": "rm -rf dist .tsbuildinfo coverage"
  },
  "dependencies": {
    "@repo/contracts": "workspace:*",
    "@repo/db": "workspace:*",
    "@repo/embedding": "workspace:*",
    "@repo/evaluation": "workspace:*",
    "@repo/github": "workspace:*",
    "@repo/queue": "workspace:*",
    "@repo/publisher": "workspace:*",
    "@repo/retrieval": "workspace:*",
    "@repo/review-engine": "workspace:*",
    "@repo/rules": "workspace:*",
    "drizzle-orm": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "postgres": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
