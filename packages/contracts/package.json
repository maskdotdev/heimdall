{
  "name": "@repo/contracts",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./api/*": {
      "types": "./dist/api/*.d.ts",
      "import": "./dist/api/*.js"
    },
    "./enums/*": {
      "types": "./dist/enums/*.d.ts",
      "import": "./dist/enums/*.js"
    },
    "./fixtures/*": {
      "types": "./dist/fixtures/*.d.ts",
      "import": "./dist/fixtures/*.js"
    },
    "./identity/*": {
      "types": "./dist/identity/*.d.ts",
      "import": "./dist/identity/*.js"
    },
    "./index-artifact/*": {
      "types": "./dist/index-artifact/*.d.ts",
      "import": "./dist/index-artifact/*.js"
    },
    "./jobs/*": {
      "types": "./dist/jobs/*.d.ts",
      "import": "./dist/jobs/*.js"
    },
    "./llm/*": {
      "types": "./dist/llm/*.d.ts",
      "import": "./dist/llm/*.js"
    },
    "./memory/*": {
      "types": "./dist/memory/*.d.ts",
      "import": "./dist/memory/*.js"
    },
    "./primitives/*": {
      "types": "./dist/primitives/*.d.ts",
      "import": "./dist/primitives/*.js"
    },
    "./pull-request/*": {
      "types": "./dist/pull-request/*.d.ts",
      "import": "./dist/pull-request/*.js"
    },
    "./repository/*": {
      "types": "./dist/repository/*.d.ts",
      "import": "./dist/repository/*.js"
    },
    "./review/*": {
      "types": "./dist/review/*.d.ts",
      "import": "./dist/review/*.js"
    },
    "./usage/*": {
      "types": "./dist/usage/*.d.ts",
      "import": "./dist/usage/*.js"
    },
    "./validation/*": {
      "types": "./dist/validation/*.d.ts",
      "import": "./dist/validation/*.js"
    },
    "./webhook/*": {
      "types": "./dist/webhook/*.d.ts",
      "import": "./dist/webhook/*.js"
    }
  },
  "imports": {
    "#contracts/*": "./src/*.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests",
    "lint": "biome check .",
    "format": "biome format --write .",
    "clean": "rm -rf dist .tsbuildinfo coverage"
  },
  "dependencies": {
    "@repo/index-schema": "workspace:*",
    "@sinclair/typebox": "catalog:",
    "ajv": "catalog:",
    "ajv-formats": "catalog:"
  },
  "devDependencies": {
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
