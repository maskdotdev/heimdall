# Runtime
NODE_ENV=development
LOG_LEVEL=debug

# API
PORT=3000
WEB_URL=http://localhost:3001
API_URL=http://localhost:3000

# Internal admin-debug API. Disabled unless explicitly enabled.
HEIMDALL_ADMIN_DEBUG_ENABLED=false
HEIMDALL_ADMIN_DEBUG_TOKEN=

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/review_agent

# Redis / queues
REDIS_URL=redis://localhost:6379

# GitHub App placeholders
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# LLM providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Object storage, optional in MVP
S3_ENDPOINT=
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=
