# Runtime
NODE_ENV=development
LOG_LEVEL=debug

# API
PORT=3000
WEB_URL=http://localhost:3001
API_URL=http://localhost:3000

# Dashboard build-time login configuration.
VITE_HEIMDALL_API_BASE_URL=http://localhost:3000
VITE_HEIMDALL_ADMIN_GATEWAY_BASE_URL=http://localhost:4318

# Product dashboard and GitHub App install flow.
HEIMDALL_API_PUBLIC_URL=http://localhost:3000
HEIMDALL_APP_ALLOWED_ORIGINS=http://localhost:3001
HEIMDALL_GITHUB_APP_SLUG=
HEIMDALL_GITHUB_APP_INSTALL_URL=

# Product session auth and GitHub OAuth.
HEIMDALL_PRODUCT_AUTH_ENABLED=true
HEIMDALL_PRODUCT_SESSION_PEPPER=local-product-session-pepper-with-at-least-32-chars
HEIMDALL_PRODUCT_COOKIE_SAME_SITE=Lax
HEIMDALL_PRODUCT_SESSION_TTL_DAYS=14
HEIMDALL_PRODUCT_RATE_LIMIT_MAX_REQUESTS=600
HEIMDALL_PRODUCT_RATE_LIMIT_WINDOW_SECONDS=60
HEIMDALL_PRODUCT_RATE_LIMIT_MAX_ENTRIES=25000
HEIMDALL_PRODUCT_AUTH_DEFAULT_REDIRECT_PATH=/
HEIMDALL_GITHUB_OAUTH_ENABLED=true
HEIMDALL_GITHUB_OAUTH_CLIENT_ID=
HEIMDALL_GITHUB_OAUTH_CLIENT_SECRET=
HEIMDALL_GITHUB_OAUTH_CALLBACK_URL=http://localhost:3000/api/v1/auth/github/callback
HEIMDALL_GITHUB_OAUTH_SCOPES=read:user,user:email

# Admin control-plane API. Disabled unless explicitly enabled and fully configured.
HEIMDALL_ADMIN_ENABLED=false
# Use "internal" behind a trusted proxy or "public" only with strict IdP and CORS configuration.
HEIMDALL_ADMIN_ROUTE_EXPOSURE=disabled
HEIMDALL_ADMIN_IDENTITY_PROVIDER=oidc
HEIMDALL_ADMIN_IDENTITY_ASSERTION_SECRET=
HEIMDALL_ADMIN_SESSION_SECRET=
HEIMDALL_ADMIN_ALLOWED_ORIGINS=http://localhost:3001
HEIMDALL_ADMIN_INTERNAL_HEADER_NAME=
HEIMDALL_ADMIN_INTERNAL_HEADER_VALUE=
HEIMDALL_ADMIN_GITHUB_ORG=

# Real GitHub-org admin identity gateway. The assertion secret must match the API value above.
HEIMDALL_ADMIN_GATEWAY_HOST=0.0.0.0
HEIMDALL_ADMIN_GATEWAY_PORT=4318
HEIMDALL_ADMIN_GATEWAY_PUBLIC_URL=
HEIMDALL_ADMIN_GATEWAY_DASHBOARD_URL=
HEIMDALL_ADMIN_GATEWAY_SESSION_SECRET=
HEIMDALL_ADMIN_GATEWAY_SESSION_MAX_AGE_SECONDS=28800
HEIMDALL_ADMIN_GATEWAY_OAUTH_STATE_MAX_AGE_SECONDS=900
HEIMDALL_ADMIN_GATEWAY_ALLOWED_ORIGINS=
HEIMDALL_ADMIN_GATEWAY_ALLOWED_LOGINS=
HEIMDALL_ADMIN_GATEWAY_ALLOW_ALL_ORG_MEMBERS=false
HEIMDALL_ADMIN_GATEWAY_ORG_IDS=
HEIMDALL_ADMIN_GATEWAY_REPO_IDS=
HEIMDALL_ADMIN_GATEWAY_PERMISSIONS=admin.inspect,admin.replay.plan,admin.replay.execute,admin.settings.manage,admin.audit.view
HEIMDALL_ADMIN_GATEWAY_GITHUB_CLIENT_ID=
HEIMDALL_ADMIN_GATEWAY_GITHUB_CLIENT_SECRET=
HEIMDALL_ADMIN_GATEWAY_GITHUB_SCOPES=read:org

# Admin control-plane smoke gates. These values are for staging proof only.
HEIMDALL_ADMIN_SMOKE_ASSERTION_URL=
HEIMDALL_ADMIN_SMOKE_ORIGIN=
HEIMDALL_ADMIN_SMOKE_ASSERTION_BEARER_TOKEN=
HEIMDALL_ADMIN_SMOKE_GATEWAY_COOKIE=
HEIMDALL_ADMIN_SMOKE_ASSERTION_METHOD=POST
HEIMDALL_ADMIN_SMOKE_ALLOW_LOCAL_TARGET=false
HEIMDALL_ADMIN_SMOKE_ORG_ID=
HEIMDALL_ADMIN_SMOKE_REPO_ID=
HEIMDALL_DASHBOARD_E2E_BROWSER_WS=
HEIMDALL_DASHBOARD_E2E_REPLAY_KIND=
HEIMDALL_DASHBOARD_E2E_REPLAY_ID=
HEIMDALL_DASHBOARD_E2E_ALLOW_SETTINGS_WRITE=false
HEIMDALL_DASHBOARD_E2E_ALLOW_REPLAY_WRITE=false
HEIMDALL_CONTROL_PLANE_EVIDENCE_FILE=docs/evidence/admin-control-plane-staging-proof.json
HEIMDALL_CONTROL_PLANE_MANUAL_DRILL_EVIDENCE=
HEIMDALL_CONTROL_PLANE_ROLLBACK_NOTES=

# Local-only identity gateway used while developing the admin control plane.
HEIMDALL_DEV_ADMIN_IDP_HOST=127.0.0.1
HEIMDALL_DEV_ADMIN_IDP_PORT=4317
HEIMDALL_DEV_ADMIN_IDP_PROVIDER=oidc
HEIMDALL_DEV_ADMIN_IDP_SUBJECT=dev-admin
HEIMDALL_DEV_ADMIN_IDP_EMAIL=dev-admin@example.local
HEIMDALL_DEV_ADMIN_IDP_DISPLAY_NAME=Dev Admin
HEIMDALL_DEV_ADMIN_IDP_ORG_IDS=org_local
HEIMDALL_DEV_ADMIN_IDP_REPO_IDS=
HEIMDALL_DEV_ADMIN_IDP_PERMISSIONS=admin.inspect,admin.replay.plan,admin.replay.execute,admin.settings.manage,admin.audit.view

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/review_agent

# Redis / queues
REDIS_URL=redis://localhost:6379
HEIMDALL_QUEUE_STALE_RUNNING_JOB_TIMEOUT_MS=21600000
HEIMDALL_QUEUE_STALE_RUNNING_JOB_RECOVERY_INTERVAL_MS=60000
HEIMDALL_QUEUE_STALE_RUNNING_JOB_RECOVERY_BATCH_SIZE=100

# GitHub App placeholders
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Review LLM providers. Leave LLM_PROVIDER empty to keep real model calls disabled.
LLM_PROVIDER=
LLM_MODEL=
LLM_MODEL_PROFILE=review_llm
LLM_PROVIDER_API_KEY_SECRET_REF=
LLM_PROVIDER_API_KEY=
LLM_PROVIDER_BASE_URL=
LLM_PROVIDER_TIMEOUT_MS=30000
HEIMDALL_REVIEW_SMOKE_FINDING=false
OPENAI_API_KEY=
OPENAI_API_KEY_SECRET_REF=
OPENAI_MODEL=
OPENAI_BASE_URL=
ANTHROPIC_API_KEY=

# Embedding providers. Defaults to local hash vectors; set EMBEDDING_PROVIDER=openai for real vectors.
EMBEDDING_PROVIDER=hash
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
EMBEDDING_PROVIDER_API_KEY_SECRET_REF=
EMBEDDING_PROVIDER_API_KEY=
EMBEDDING_PROVIDER_BASE_URL=
EMBEDDING_PROVIDER_TIMEOUT_MS=30000
OPENAI_EMBEDDING_API_KEY=
OPENAI_EMBEDDING_API_KEY_SECRET_REF=

# Object storage, optional in MVP
S3_ENDPOINT=
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=
