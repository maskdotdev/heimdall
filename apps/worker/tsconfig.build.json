    { "path": "../../packages/config/tsconfig.build.json" },
    { "path": "../../packages/contracts/tsconfig.build.json" },
    { "path": "../../packages/db/tsconfig.build.json" },
    { "path": "../../packages/github/tsconfig.build.json" },
    { "path": "../../packages/queue/tsconfig.build.json" },
    { "path": "../../packages/repo-sync/tsconfig.build.json" }
  ]
}
