# Live GitHub smoke tests.
# Copy this file to .env.smoke.local. The local file is ignored by Git.

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/review_agent
REDIS_URL=redis://localhost:6379
HEIMDALL_DB_TEST_URL=postgresql://postgres:postgres@localhost:5432/review_agent_test
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
GITHUB_WEBHOOK_SECRET=local-smoke-secret
HEIMDALL_REVIEW_SMOKE_FINDING=true
HEIMDALL_GITHUB_SMOKE_PROVIDER_INSTALLATION_ID=
HEIMDALL_GITHUB_SMOKE_OWNER=
HEIMDALL_GITHUB_SMOKE_REPO=
HEIMDALL_GITHUB_SMOKE_PR=
HEIMDALL_GITHUB_SMOKE_ALLOW_WRITE=false

# Optional. Defaults to HEIMDALL_GITHUB_SMOKE_PROVIDER_INSTALLATION_ID.
HEIMDALL_GITHUB_SMOKE_INSTALLATION_ID=

# Optional live GitHub provider-error smoke controls. The default not_found case is read-only.
HEIMDALL_GITHUB_ERROR_SMOKE_CASES=not_found
HEIMDALL_GITHUB_ERROR_SMOKE_NOT_FOUND_REPO=
HEIMDALL_GITHUB_ERROR_SMOKE_INVALID_HEAD_SHA=heimdall-invalid-sha
HEIMDALL_GITHUB_ERROR_SMOKE_ALLOW_INVALID_WRITE=false

# Optional live PR review smoke controls.
HEIMDALL_GITHUB_REVIEW_SMOKE_WEBHOOK_URL=http://localhost:3000/webhooks/github
HEIMDALL_GITHUB_REVIEW_SMOKE_BASE_BRANCH=
HEIMDALL_GITHUB_REVIEW_SMOKE_BRANCH=heimdall/smoke-pr-review
HEIMDALL_GITHUB_REVIEW_SMOKE_FILE=heimdall-smoke/pr-review-smoke.txt
HEIMDALL_GITHUB_REVIEW_SMOKE_TIMEOUT_MS=180000
HEIMDALL_GITHUB_REVIEW_SMOKE_POLL_MS=2000

# Optional. Set true to let the review smoke use `gh auth token` for throwaway branch writes
# when the GitHub App installation cannot mutate repository contents.
HEIMDALL_GITHUB_REVIEW_SMOKE_GH_TOKEN_FALLBACK=false

# Optional live OpenAI-compatible embedding smoke. This makes a real provider call only when
# HEIMDALL_EMBEDDING_SMOKE_ALLOW_LIVE=true.
HEIMDALL_EMBEDDING_SMOKE_ALLOW_LIVE=false
HEIMDALL_EMBEDDING_PROVIDER_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=1536
OPENAI_EMBEDDING_BASE_URL=https://api.openai.com/v1
OPENAI_EMBEDDING_TIMEOUT_MS=30000

# Optional live OpenAI-compatible LLM smoke. This makes a real provider call only when
# HEIMDALL_LLM_SMOKE_ALLOW_LIVE=true.
HEIMDALL_LLM_SMOKE_ALLOW_LIVE=false
HEIMDALL_LLM_PROVIDER_API_KEY=
HEIMDALL_LLM_SMOKE_MODEL=
HEIMDALL_LLM_BASE_URL=https://api.openai.com/v1
HEIMDALL_LLM_TIMEOUT_MS=30000
HEIMDALL_LLM_SMOKE_MAX_COMPLETION_TOKENS=128
OPENAI_ORGANIZATION=
OPENAI_PROJECT=

# Local admin control-plane development smoke. The dev IdP is localhost-only and is not a
# replacement for staging OIDC/SAML/GitHub-org proof.
API_URL=http://localhost:3000
WEB_URL=http://localhost:3001
VITE_HEIMDALL_API_BASE_URL=http://localhost:3000
VITE_HEIMDALL_ADMIN_GATEWAY_BASE_URL=http://127.0.0.1:4317/assertion
HEIMDALL_ADMIN_ENABLED=true
HEIMDALL_ADMIN_ROUTE_EXPOSURE=public
HEIMDALL_ADMIN_IDENTITY_PROVIDER=oidc
HEIMDALL_ADMIN_IDENTITY_ASSERTION_SECRET=local-admin-assertion-secret-with-32-chars
HEIMDALL_ADMIN_SESSION_SECRET=local-admin-session-secret-with-32-chars
HEIMDALL_ADMIN_ALLOWED_ORIGINS=http://localhost:3001
HEIMDALL_ADMIN_SMOKE_ASSERTION_URL=http://127.0.0.1:4317/assertion
HEIMDALL_ADMIN_SMOKE_ORIGIN=http://localhost:3001
HEIMDALL_ADMIN_SMOKE_GATEWAY_COOKIE=
HEIMDALL_ADMIN_SMOKE_ORG_ID=org_local
HEIMDALL_ADMIN_SMOKE_REPO_ID=repo_local
# The local smoke package script sets HEIMDALL_ADMIN_SMOKE_ALLOW_LOCAL_TARGET=true. Keep this unset
# or false for staging proof commands so they fail closed on localhost targets.
HEIMDALL_ADMIN_SMOKE_ALLOW_LOCAL_TARGET=
HEIMDALL_DASHBOARD_E2E_BROWSER_WS=
HEIMDALL_DASHBOARD_E2E_REPLAY_KIND=
HEIMDALL_DASHBOARD_E2E_REPLAY_ID=
HEIMDALL_DASHBOARD_E2E_ALLOW_SETTINGS_WRITE=false
HEIMDALL_DASHBOARD_E2E_ALLOW_REPLAY_WRITE=false
HEIMDALL_CONTROL_PLANE_EVIDENCE_FILE=docs/evidence/admin-control-plane-staging-proof.json
HEIMDALL_CONTROL_PLANE_MANUAL_DRILL_EVIDENCE=
HEIMDALL_CONTROL_PLANE_ROLLBACK_NOTES=
HEIMDALL_DEV_ADMIN_IDP_HOST=127.0.0.1
HEIMDALL_DEV_ADMIN_IDP_PORT=4317
HEIMDALL_DEV_ADMIN_IDP_PROVIDER=oidc
HEIMDALL_DEV_ADMIN_IDP_SUBJECT=dev-admin
HEIMDALL_DEV_ADMIN_IDP_EMAIL=dev-admin@example.local
HEIMDALL_DEV_ADMIN_IDP_DISPLAY_NAME=Dev Admin
HEIMDALL_DEV_ADMIN_IDP_ORG_IDS=org_local
HEIMDALL_DEV_ADMIN_IDP_REPO_IDS=
HEIMDALL_DEV_ADMIN_IDP_PERMISSIONS=admin.inspect,admin.replay.plan,admin.replay.execute,admin.settings.manage,admin.audit.view

# Real GitHub-org gateway staging proof values. Use these instead of dev-admin-idp values when
# proving the trusted admin path.
HEIMDALL_ADMIN_GATEWAY_HOST=0.0.0.0
HEIMDALL_ADMIN_GATEWAY_PORT=4318
HEIMDALL_ADMIN_GATEWAY_PUBLIC_URL=
HEIMDALL_ADMIN_GATEWAY_DASHBOARD_URL=
HEIMDALL_ADMIN_GATEWAY_SESSION_SECRET=
HEIMDALL_ADMIN_GATEWAY_SESSION_MAX_AGE_SECONDS=28800
HEIMDALL_ADMIN_GATEWAY_OAUTH_STATE_MAX_AGE_SECONDS=900
HEIMDALL_ADMIN_GATEWAY_ALLOWED_ORIGINS=
HEIMDALL_ADMIN_GATEWAY_ALLOWED_LOGINS=
HEIMDALL_ADMIN_GATEWAY_ALLOW_ALL_ORG_MEMBERS=false
HEIMDALL_ADMIN_GITHUB_ORG=
HEIMDALL_ADMIN_GATEWAY_ORG_IDS=
HEIMDALL_ADMIN_GATEWAY_REPO_IDS=
HEIMDALL_ADMIN_GATEWAY_PERMISSIONS=admin.inspect,admin.replay.plan,admin.replay.execute,admin.settings.manage,admin.audit.view
HEIMDALL_ADMIN_GATEWAY_GITHUB_CLIENT_ID=
HEIMDALL_ADMIN_GATEWAY_GITHUB_CLIENT_SECRET=
HEIMDALL_ADMIN_GATEWAY_GITHUB_SCOPES=read:org
