{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "infra/staging/Dockerfile.admin-gateway",
    "watchPatterns": [
      "apps/admin-gateway/**",
      "packages/security/**",
      "packages/config/**",
      "infra/staging/Dockerfile.admin-gateway",
      "package.json",
      "pnpm-lock.yaml",
      "pnpm-workspace.yaml",
      "turbo.json",
      "tsconfig.base.json"
    ]
  },
  "deploy": {
    "healthcheckPath": "/healthz",
    "healthcheckTimeout": 120,
    "restartPolicyMaxRetries": 3,
    "restartPolicyType": "ON_FAILURE",
    "startCommand": "pnpm --filter @app/admin-gateway start"
  }
}
