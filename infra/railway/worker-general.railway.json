{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "infra/staging/Dockerfile.worker",
    "watchPatterns": [
      "apps/worker/**",
      "packages/**",
      "infra/staging/Dockerfile.worker",
      "package.json",
      "pnpm-lock.yaml",
      "pnpm-workspace.yaml",
      "turbo.json",
      "tsconfig.base.json"
    ]
  },
  "deploy": {
    "restartPolicyMaxRetries": 3,
    "restartPolicyType": "ON_FAILURE",
    "startCommand": "HEIMDALL_WORKER_ROLE=repo-sync,memory,billing,security pnpm --filter @app/worker start"
  }
}
