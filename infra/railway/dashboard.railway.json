{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "infra/staging/Dockerfile.web",
    "watchPatterns": [
      "apps/web/**",
      "packages/contracts/**",
      "infra/staging/Dockerfile.web",
      "package.json",
      "pnpm-lock.yaml",
      "pnpm-workspace.yaml",
      "turbo.json",
      "tsconfig.base.json"
    ]
  },
  "deploy": {
    "healthcheckPath": "/",
    "healthcheckTimeout": 120,
    "restartPolicyMaxRetries": 3,
    "restartPolicyType": "ON_FAILURE",
    "startCommand": "pnpm --filter @app/web start"
  }
}
