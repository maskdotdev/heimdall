{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "infra/staging/Dockerfile.api",
    "watchPatterns": [
      "apps/api/**",
      "packages/**",
      "infra/staging/Dockerfile.api",
      "package.json",
      "pnpm-lock.yaml",
      "pnpm-workspace.yaml",
      "turbo.json",
      "tsconfig.base.json"
    ]
  },
  "deploy": {
    "healthcheckPath": "/healthz",
    "healthcheckTimeout": 120,
    "restartPolicyMaxRetries": 3,
    "restartPolicyType": "ON_FAILURE",
    "startCommand": "pnpm --filter @app/api start"
  }
}
