{
  "environment": "production",
  "artifactStorage": {
    "bucketAccess": "private",
    "encryption": "provider-managed",
    "provider": "s3-compatible",
    "publicAccess": "blocked",
    "rawDownloadAccess": "support-session-gated"
  },
  "observability": {
    "alerts": [
      {
        "id": "admin_api_health",
        "query": "api /healthz is not healthy for 2 consecutive checks",
        "severity": "critical"
      },
      {
        "id": "admin_gateway_health",
        "query": "admin gateway /healthz is not healthy for 2 consecutive checks",
        "severity": "critical"
      },
      {
        "id": "admin_dashboard_health",
        "query": "dashboard static health check fails for 2 consecutive checks",
        "severity": "critical"
      },
      {
        "id": "admin_auth_failure_rate",
        "query": "admin.access.denied count exceeds baseline in 5 minutes",
        "severity": "warning"
      },
      {
        "id": "admin_replay_dispatch_audit",
        "query": "admin.replay.dispatched event has no matching replay audit row",
        "severity": "critical"
      },
      {
        "id": "admin_settings_update_audit",
        "query": "admin.settings.updated event has no matching repo.settings.updated audit row",
        "severity": "critical"
      },
      {
        "id": "admin_emergency_disable",
        "query": "HEIMDALL_ADMIN_ENABLED=false rollback verification fails",
        "severity": "critical"
      }
    ],
    "dashboards": [
      {
        "id": "admin_control_plane_health",
        "owner": "operations",
        "signals": [
          "api /healthz",
          "admin gateway /healthz",
          "dashboard root",
          "production API URL in dashboard bundle"
        ],
        "title": "Admin Control-Plane Health"
      },
      {
        "id": "admin_auth_access",
        "owner": "security",
        "signals": [
          "admin.access.denied telemetry",
          "admin.auth.success telemetry",
          "admin gateway rejection logs",
          "allowed-login changes"
        ],
        "title": "Admin Auth and Access"
      },
      {
        "id": "admin_actions_audit",
        "owner": "api-dashboard",
        "signals": [
          "admin.action.completed telemetry",
          "admin.replay.dispatched telemetry",
          "repo.settings.updated audit rows",
          "debug export and eval import audit rows"
        ],
        "title": "Admin Actions and Audit"
      },
      {
        "id": "admin_worker_queues",
        "owner": "operations",
        "signals": [
          "worker heartbeat logs",
          "background job queue depth",
          "oldest pending job age",
          "role-specific worker failures"
        ],
        "title": "Admin Worker Queues"
      },
      {
        "id": "admin_data_services",
        "owner": "operations",
        "signals": [
          "Postgres connection health",
          "Redis connection health",
          "database migration gate status",
          "queue recovery checks"
        ],
        "title": "Admin Data Services"
      },
      {
        "id": "admin_artifact_security",
        "owner": "security",
        "signals": [
          "review artifact storage errors",
          "support-session raw access denials",
          "artifact access audit rows",
          "object storage policy checks"
        ],
        "title": "Admin Artifact Security"
      },
      {
        "id": "admin_release_rollback",
        "owner": "release-owner",
        "signals": [
          "Railway deployment revisions",
          "release gate results",
          "emergency disable verification",
          "rollback command output"
        ],
        "title": "Admin Release and Rollback"
      }
    ],
    "telemetryEvents": [
      "admin.access.denied",
      "admin.auth.success",
      "admin.replay.dispatched",
      "admin.session.revoked",
      "admin.settings.updated"
    ]
  },
  "provider": "railway",
  "releaseGates": [
    {
      "command": "pnpm release:control-plane:railway",
      "name": "single-command Railway release sequence"
    },
    {
      "command": "pnpm check",
      "name": "workspace check"
    },
    {
      "command": "pnpm preflight:control-plane:staging",
      "name": "staging preflight"
    },
    {
      "command": "pnpm smoke:control-plane:staging",
      "name": "staging smoke"
    },
    {
      "command": "pnpm e2e:dashboard",
      "name": "dashboard e2e"
    },
    {
      "command": "pnpm proof:control-plane:staging",
      "name": "staging proof"
    },
    {
      "command": "pnpm proof:sandbox:staging",
      "name": "sandbox staging proof"
    },
    {
      "command": "pnpm readiness:control-plane:production",
      "name": "production readiness"
    }
  ],
  "rollback": {
    "commands": [
      "railway variables --set HEIMDALL_ADMIN_ENABLED=false --service api",
      "railway redeploy --service api",
      "railway rollback --service api",
      "railway rollback --service admin-gateway",
      "railway rollback --service dashboard"
    ],
    "checks": [
      "Admin routes return 404 after emergency disable",
      "Dashboard cannot create a new session",
      "Last successful deployment can be restored for api, dashboard, and admin-gateway"
    ]
  },
  "services": [
    {
      "dockerfile": "infra/staging/Dockerfile.api",
      "healthCheck": "/healthz",
      "name": "api",
      "package": "@app/api",
      "railwayConfig": "infra/railway/api.railway.json",
      "requiredEnv": [
        "DATABASE_URL",
        "REDIS_URL",
        "GITHUB_WEBHOOK_SECRET_REF",
        "HEIMDALL_ADMIN_ENABLED",
        "HEIMDALL_ADMIN_ROUTE_EXPOSURE",
        "HEIMDALL_ADMIN_IDENTITY_PROVIDER",
        "HEIMDALL_ADMIN_IDENTITY_ASSERTION_SECRET",
        "HEIMDALL_ADMIN_SESSION_SECRET",
        "HEIMDALL_ADMIN_ALLOWED_ORIGINS",
        "HEIMDALL_ADMIN_GITHUB_ORG",
        "WEB_URL",
        "AWS_ACCESS_KEY_ID",
        "AWS_REGION",
        "AWS_SECRET_ACCESS_KEY",
        "HEIMDALL_REVIEW_ARTIFACT_BUCKET",
        "HEIMDALL_REVIEW_ARTIFACT_ENDPOINT",
        "HEIMDALL_REVIEW_ARTIFACT_REGION",
        "HEIMDALL_REVIEW_ARTIFACT_ACCESS_KEY_ID",
        "HEIMDALL_REVIEW_ARTIFACT_SECRET_ACCESS_KEY"
      ]
    },
    {
      "dockerfile": "infra/staging/Dockerfile.web",
      "healthCheck": "/",
      "name": "dashboard",
      "package": "@app/web",
      "railwayConfig": "infra/railway/dashboard.railway.json",
      "requiredEnv": [
        "VITE_HEIMDALL_API_BASE_URL",
        "VITE_HEIMDALL_ADMIN_GATEWAY_BASE_URL"
      ]
    },
    {
      "dockerfile": "infra/staging/Dockerfile.admin-gateway",
      "healthCheck": "/healthz",
      "name": "admin-gateway",
      "package": "@app/admin-gateway",
      "railwayConfig": "infra/railway/admin-gateway.railway.json",
      "requiredEnv": [
        "GITHUB_CLIENT_ID",
        "GITHUB_CLIENT_SECRET",
        "HEIMDALL_ADMIN_GATEWAY_PUBLIC_URL",
        "HEIMDALL_ADMIN_GATEWAY_DASHBOARD_URL",
        "HEIMDALL_ADMIN_GATEWAY_SESSION_SECRET",
        "HEIMDALL_ADMIN_GATEWAY_ALLOWED_LOGINS",
        "HEIMDALL_ADMIN_GATEWAY_ORG_IDS",
        "HEIMDALL_ADMIN_GATEWAY_PERMISSIONS",
        "HEIMDALL_ADMIN_IDENTITY_ASSERTION_SECRET",
        "HEIMDALL_ADMIN_GITHUB_ORG"
      ]
    },
    {
      "dockerfile": "infra/staging/Dockerfile.worker",
      "healthCheck": "worker heartbeat log",
      "name": "worker-general",
      "package": "@app/worker",
      "railwayConfig": "infra/railway/worker-general.railway.json",
      "requiredEnv": [
        "DATABASE_URL",
        "REDIS_URL",
        "GITHUB_APP_ID",
        "GITHUB_APP_PRIVATE_KEY_SECRET_REF",
        "AWS_ACCESS_KEY_ID",
        "AWS_REGION",
        "AWS_SECRET_ACCESS_KEY",
        "HEIMDALL_REVIEW_ARTIFACT_BUCKET",
        "HEIMDALL_REVIEW_ARTIFACT_ENDPOINT",
        "HEIMDALL_REVIEW_ARTIFACT_REGION",
        "HEIMDALL_REVIEW_ARTIFACT_ACCESS_KEY_ID",
        "HEIMDALL_REVIEW_ARTIFACT_SECRET_ACCESS_KEY"
      ],
      "workerRole": "repo-sync,memory,billing,security"
    },
    {
      "dockerfile": "infra/staging/Dockerfile.worker",
      "healthCheck": "worker heartbeat log",
      "name": "worker-index",
      "package": "@app/worker",
      "railwayConfig": "infra/railway/worker-index.railway.json",
      "requiredEnv": [
        "DATABASE_URL",
        "REDIS_URL",
        "GITHUB_APP_ID",
        "GITHUB_APP_PRIVATE_KEY_SECRET_REF",
        "AWS_ACCESS_KEY_ID",
        "AWS_REGION",
        "AWS_SECRET_ACCESS_KEY",
        "HEIMDALL_REVIEW_ARTIFACT_BUCKET",
        "HEIMDALL_REVIEW_ARTIFACT_ENDPOINT",
        "HEIMDALL_REVIEW_ARTIFACT_REGION",
        "HEIMDALL_REVIEW_ARTIFACT_ACCESS_KEY_ID",
        "HEIMDALL_REVIEW_ARTIFACT_SECRET_ACCESS_KEY"
      ],
      "workerRole": "index"
    },
    {
      "dockerfile": "infra/staging/Dockerfile.worker",
      "healthCheck": "worker heartbeat log",
      "name": "worker-review",
      "package": "@app/worker",
      "railwayConfig": "infra/railway/worker-review.railway.json",
      "requiredEnv": [
        "DATABASE_URL",
        "REDIS_URL",
        "GITHUB_APP_ID",
        "GITHUB_APP_PRIVATE_KEY_SECRET_REF",
        "AWS_ACCESS_KEY_ID",
        "AWS_REGION",
        "AWS_SECRET_ACCESS_KEY",
        "HEIMDALL_REVIEW_ARTIFACT_BUCKET",
        "HEIMDALL_REVIEW_ARTIFACT_ENDPOINT",
        "HEIMDALL_REVIEW_ARTIFACT_REGION",
        "HEIMDALL_REVIEW_ARTIFACT_ACCESS_KEY_ID",
        "HEIMDALL_REVIEW_ARTIFACT_SECRET_ACCESS_KEY",
        "HEIMDALL_LLM_PROVIDER",
        "HEIMDALL_LLM_MODEL",
        "HEIMDALL_LLM_PROVIDER_API_KEY_SECRET_REF"
      ],
      "workerRole": "review"
    },
    {
      "dockerfile": "infra/staging/Dockerfile.worker",
      "healthCheck": "worker heartbeat log",
      "name": "worker-embedding",
      "package": "@app/worker",
      "railwayConfig": "infra/railway/worker-embedding.railway.json",
      "requiredEnv": [
        "DATABASE_URL",
        "REDIS_URL",
        "GITHUB_APP_ID",
        "GITHUB_APP_PRIVATE_KEY_SECRET_REF",
        "AWS_ACCESS_KEY_ID",
        "AWS_REGION",
        "AWS_SECRET_ACCESS_KEY",
        "HEIMDALL_REVIEW_ARTIFACT_BUCKET",
        "HEIMDALL_REVIEW_ARTIFACT_ENDPOINT",
        "HEIMDALL_REVIEW_ARTIFACT_REGION",
        "HEIMDALL_REVIEW_ARTIFACT_ACCESS_KEY_ID",
        "HEIMDALL_REVIEW_ARTIFACT_SECRET_ACCESS_KEY",
        "HEIMDALL_EMBEDDING_PROVIDER",
        "HEIMDALL_EMBEDDING_MODEL",
        "HEIMDALL_EMBEDDING_API_KEY_SECRET_REF"
      ],
      "workerRole": "embedding"
    },
    {
      "dockerfile": "infra/staging/Dockerfile.worker",
      "healthCheck": "worker heartbeat log",
      "name": "worker-publisher",
      "package": "@app/worker",
      "railwayConfig": "infra/railway/worker-publisher.railway.json",
      "requiredEnv": [
        "DATABASE_URL",
        "REDIS_URL",
        "GITHUB_APP_ID",
        "GITHUB_APP_PRIVATE_KEY_SECRET_REF",
        "AWS_ACCESS_KEY_ID",
        "AWS_REGION",
        "AWS_SECRET_ACCESS_KEY",
        "HEIMDALL_REVIEW_ARTIFACT_BUCKET",
        "HEIMDALL_REVIEW_ARTIFACT_ENDPOINT",
        "HEIMDALL_REVIEW_ARTIFACT_REGION",
        "HEIMDALL_REVIEW_ARTIFACT_ACCESS_KEY_ID",
        "HEIMDALL_REVIEW_ARTIFACT_SECRET_ACCESS_KEY"
      ],
      "workerRole": "publisher"
    },
    {
      "dockerfile": "infra/staging/Dockerfile.worker",
      "healthCheck": "worker heartbeat log",
      "name": "worker-maintenance",
      "package": "@app/worker",
      "railwayConfig": "infra/railway/worker-maintenance.railway.json",
      "requiredEnv": [
        "DATABASE_URL",
        "REDIS_URL",
        "GITHUB_APP_ID",
        "GITHUB_APP_PRIVATE_KEY_SECRET_REF",
        "AWS_ACCESS_KEY_ID",
        "AWS_REGION",
        "AWS_SECRET_ACCESS_KEY",
        "HEIMDALL_REVIEW_ARTIFACT_BUCKET",
        "HEIMDALL_REVIEW_ARTIFACT_ENDPOINT",
        "HEIMDALL_REVIEW_ARTIFACT_REGION",
        "HEIMDALL_REVIEW_ARTIFACT_ACCESS_KEY_ID",
        "HEIMDALL_REVIEW_ARTIFACT_SECRET_ACCESS_KEY"
      ],
      "workerRole": "maintenance"
    },
    {
      "healthCheck": "railway postgres connection healthy",
      "name": "postgres",
      "package": "railway-postgres",
      "requiredEnv": ["DATABASE_URL"]
    },
    {
      "healthCheck": "railway redis connection healthy",
      "name": "redis",
      "package": "railway-redis",
      "requiredEnv": ["REDIS_URL"]
    }
  ],
  "version": 1
}
