{
  "name": "heimdall",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.3",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0",
    "bun": ">=1.2.0"
  },
  "scripts": {
    "dev": "turbo dev",
    "dev:admin-gateway": "set -a; [ ! -f .env.smoke.local ] || . ./.env.smoke.local; set +a; pnpm --filter @app/admin-gateway dev",
    "dev:api": "turbo dev --filter=@app/api",
    "dev:admin-idp": "set -a; [ ! -f .env.smoke.local ] || . ./.env.smoke.local; set +a; bun run scripts/dev-admin-idp.ts",
    "dev:validate-artifact": "pnpm --filter @app/indexer-cli dev -- validate",
    "dev:marketing": "turbo dev --filter=@app/marketing",
    "dev:web": "turbo dev --filter=@app/web",
    "dev:worker": "turbo dev --filter=@app/worker",
    "build": "turbo build",
    "typecheck": "turbo typecheck",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "test": "vitest run --passWithNoTests test/*.test.ts && turbo test",
    "test:watch": "vitest --watch",
    "eval": "pnpm --filter @repo/evaluation eval",
    "eval:ci": "pnpm eval run --suite smoke-full-pipeline-v1 --variant local --no-live-models --output-dir .tmp/eval-runs/smoke-full-pipeline-v1 --clean-output",
    "boundaries:check": "bun run scripts/check-boundaries.ts",
    "check": "pnpm typecheck && pnpm lint && pnpm test && pnpm eval:ci && pnpm boundaries:check",
    "ci:control-plane:release": "pnpm audit:control-plane:deployment && pnpm readiness:control-plane:production && pnpm check && pnpm build",
    "release:control-plane:railway": "bun run scripts/control-plane-railway-release.ts",
    "clean": "turbo clean && pnpm clean:local",
    "clean:local": "rm -rf .turbo node_modules apps/*/node_modules packages/*/node_modules apps/*/dist packages/*/dist coverage",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down",
    "infra:reset": "docker compose down -v && docker compose up -d",
    "infra:observability:up": "docker compose --profile observability up -d",
    "infra:observability:config": "docker compose --profile observability config",
    "infra:prepare": "pnpm infra:up && pnpm --filter @repo/admin-tools infra:db:prepare",
    "admin": "pnpm --filter @repo/admin-tools admin --",
    "admin:inspect-review": "pnpm --filter @repo/admin-tools admin -- review inspect",
    "admin:replay-review": "pnpm --filter @repo/admin-tools admin -- review replay",
    "admin:replay-retrieval": "pnpm --filter @repo/admin-tools admin -- review replay --stage retrieval",
    "admin:replay-validation": "pnpm --filter @repo/admin-tools admin -- review replay --stage validation",
    "admin:export-debug-bundle": "pnpm --filter @repo/admin-tools admin -- review export",
    "admin:publisher-dry-run": "pnpm --filter @repo/admin-tools admin -- publisher dry-run",
    "admin:inspect-index": "pnpm --filter @repo/admin-tools admin -- index inspect",
    "dev:show-index-version": "pnpm --filter @repo/admin-tools admin -- index inspect",
    "dev:compare-import-counts": "pnpm --filter @repo/admin-tools admin -- index inspect",
    "smoke:api": "set -a; [ ! -f .env.smoke.local ] || . ./.env.smoke.local; set +a; DATABASE_URL=${DATABASE_URL:-postgresql://postgres:postgres@localhost:5432/review_agent} REDIS_URL=${REDIS_URL:-redis://localhost:6379} GITHUB_WEBHOOK_SECRET=${GITHUB_WEBHOOK_SECRET:-local-smoke-secret} pnpm --filter @app/api dev",
    "smoke:control-plane:api": "set -a; [ ! -f .env.smoke.local ] || . ./.env.smoke.local; set +a; DATABASE_URL=${DATABASE_URL:-postgresql://postgres:postgres@localhost:5432/review_agent} REDIS_URL=${REDIS_URL:-redis://localhost:6379} GITHUB_WEBHOOK_SECRET=${GITHUB_WEBHOOK_SECRET:-local-smoke-secret} HEIMDALL_ADMIN_ENABLED=true HEIMDALL_ADMIN_ROUTE_EXPOSURE=public HEIMDALL_ADMIN_IDENTITY_PROVIDER=${HEIMDALL_ADMIN_IDENTITY_PROVIDER:-oidc} HEIMDALL_ADMIN_IDENTITY_ASSERTION_SECRET=${HEIMDALL_ADMIN_IDENTITY_ASSERTION_SECRET:-local-admin-assertion-secret-with-32-chars} HEIMDALL_ADMIN_SESSION_SECRET=${HEIMDALL_ADMIN_SESSION_SECRET:-local-admin-session-secret-with-32-chars} HEIMDALL_ADMIN_ALLOWED_ORIGINS=${HEIMDALL_ADMIN_ALLOWED_ORIGINS:-http://localhost:3001} pnpm --filter @app/api dev",
    "smoke:worker": "set -a; [ ! -f .env.smoke.local ] || . ./.env.smoke.local; set +a; DATABASE_URL=${DATABASE_URL:-postgresql://postgres:postgres@localhost:5432/review_agent} REDIS_URL=${REDIS_URL:-redis://localhost:6379} GITHUB_WEBHOOK_SECRET=${GITHUB_WEBHOOK_SECRET:-local-smoke-secret} HEIMDALL_REVIEW_SMOKE_FINDING=true pnpm --filter @app/worker dev",
    "smoke:embedding:openai": "pnpm --filter @repo/admin-tools smoke:embedding:openai",
    "smoke:llm:openai": "pnpm --filter @repo/admin-tools smoke:llm:openai",
    "smoke:github-provider-errors": "pnpm --filter @repo/admin-tools smoke:github-provider-errors",
    "smoke:review:github": "pnpm --filter @repo/admin-tools smoke:review:github",
    "smoke:control-plane:local": "set -a; [ ! -f .env.smoke.local ] || . ./.env.smoke.local; set +a; API_URL=${API_URL:-http://localhost:3000} HEIMDALL_ADMIN_SMOKE_ASSERTION_URL=${HEIMDALL_ADMIN_SMOKE_ASSERTION_URL:-http://127.0.0.1:4317/assertion} HEIMDALL_ADMIN_SMOKE_ORG_ID=${HEIMDALL_ADMIN_SMOKE_ORG_ID:-org_local} HEIMDALL_ADMIN_SMOKE_REPO_ID=${HEIMDALL_ADMIN_SMOKE_REPO_ID:-repo_local} HEIMDALL_ADMIN_SMOKE_ALLOW_LOCAL_TARGET=true bun run scripts/control-plane-staging-smoke.ts",
    "preflight:control-plane:staging": "set -a; [ ! -f .env.smoke.local ] || . ./.env.smoke.local; set +a; bun run scripts/control-plane-staging-preflight.ts",
    "proof:control-plane:staging": "set -a; [ ! -f .env.smoke.local ] || . ./.env.smoke.local; set +a; bun run scripts/control-plane-staging-proof.ts",
    "audit:control-plane:deployment": "bun run scripts/validate-production-deployment.ts",
    "readiness:control-plane:production": "bun run scripts/control-plane-production-readiness.ts",
    "smoke:control-plane:staging": "set -a; [ ! -f .env.smoke.local ] || . ./.env.smoke.local; set +a; bun run scripts/control-plane-staging-smoke.ts",
    "e2e:dashboard": "set -a; [ ! -f .env.smoke.local ] || . ./.env.smoke.local; set +a; bun run scripts/control-plane-dashboard-e2e.ts",
    "workspace:print": "bun run scripts/print-workspace.ts",
    "env:check": "bun run scripts/validate-env.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@repo/config": "workspace:*",
    "@repo/security": "workspace:*",
    "@types/bun": "catalog:",
    "@types/node": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
